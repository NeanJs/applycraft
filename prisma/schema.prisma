generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum GenerationType {
  ATS_ANALYSIS
  COVER_LETTER
  RESUME_SUMMARY
  IMPROVED_BULLETS
  RESUME_TAILOR
}

model User {
  id      String @id @default(cuid())
  clerkId String @unique
  email   String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resumes     Resume[]
  generations Generation[]
}

//
// CORE RESUME ENGINE TABLE
//
model Resume {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // INPUTS
  originalResume Json
  jobDescription String
  jobType        String?
  title          String  @default("Untitled Resume")

  // ATS SCORING (IMPORTANT: BEFORE + AFTER)
  atsBefore Int
  atsAfter  Int

  atsBreakdown Json? // keyword %, structure %, readability %, role match %

  // OUTPUTS
  optimizedResume Json
  coverLetter     String?

  // INSIGHTS LAYER (VERY IMPORTANT FOR UX/TRUST)
  missingKeywords String[] @default([])
  changesMade     String[] @default([])

  // OPTIONAL QUALITY CONTROL
  confidenceScore Float?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  generations Generation[]

  @@index([userId])
  @@index([createdAt])
}

//
// TRACK ANONYMOUS USAGE (FREE TIER LIMITS)
//
model AnonUsage {
  ip      String   @id
  count   Int      @default(1)
  resetAt DateTime

  @@index([resetAt])
}

model Generation {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  resumeId String?
  resume   Resume? @relation(fields: [resumeId], references: [id])

  type        GenerationType
  jobTitle    String?
  companyName String?

  title String?

  input  Json?
  result Json

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([resumeId])
}
